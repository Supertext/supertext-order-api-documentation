{
  "openapi": "3.0.3",
  "info": {
    "title": "Supertext Order API",
    "version": "1.1",
    "description": "The Supertext Order API lets you place and manage **professional (human) translation** orders: upload content, request a quote, create orders, receive a completion callback, and download the finished translation.\n\nThis is the Basic-auth **Order API** (also called the Legacy API). All endpoint paths are relative to the environment base URL.\n\n## Authentication\n\nThe Order API uses **HTTP Basic authentication**:\n\n- **username** = your Supertext account email\n- **password** = your **Legacy API Key** (from your Supertext account settings)\n\nSend it on every request as an `Authorization` header:\n\n    Authorization: Basic BASE64(\"email:legacyApiKey\")\n\n## Environments\n\nAll environments live under `supertext.com`:\n\n- **Production (live)** — `https://www.supertext.com`\n- **Staging** — `https://staging.supertext.com`\n- **Testing** — `https://testing.supertext.com`\n\nUse Staging or Testing for integration work; those orders are not billed and not translated by humans.\n\n## Order flow\n\n1. (optional) Verify credentials with **Account check**.\n2. Upload the content with **Upload a file** to get a DocumentId (or send it inline).\n3. Create the order(s) with **Create an order** — one order per target language.\n4. Supertext POSTs the completed order(s) to your **CallbackUrl** when finished.\n5. Download the **Final** file(s).\n\n## Order types & delivery\n\n`OrderTypeConfigurationId` selects the product/quality tier and is **account-specific** (e.g. 166 BASIC, 167 PREMIUM, 168 CREATIVE). `DeliveryId` selects speed: 1 = Express, 2 = 24h, 3 = 48h, 4 = 3 days, 5 = 1 week.",
    "contact": {
      "name": "Supertext",
      "url": "https://www.supertext.com"
    }
  },
  "servers": [
    { "url": "https://www.supertext.com", "description": "Production (live)" },
    { "url": "https://staging.supertext.com", "description": "Staging (non-billed integration)" },
    { "url": "https://testing.supertext.com", "description": "Testing (non-billed integration)" }
  ],
  "security": [{ "basicAuth": [] }],
  "tags": [
    { "name": "Account", "description": "Credential verification" },
    { "name": "Files", "description": "Upload and download documents" },
    { "name": "Orders", "description": "Quotes, orders, status and feedback" }
  ],
  "paths": {
    "/api/v1/translation/accountcheck": {
      "get": {
        "tags": ["Account"],
        "summary": "Verify credentials",
        "operationId": "accountCheck",
        "responses": {
          "200": { "description": "Credentials are valid." },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/files/files": {
      "post": {
        "tags": ["Files"],
        "summary": "Upload a document to translate",
        "operationId": "uploadFile",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["ElementId", "ElementTypeId", "DocumentTypeId", "file"],
                "properties": {
                  "ElementId": { "type": "integer", "default": 0, "description": "0 = create a new element." },
                  "ElementTypeId": { "type": "integer", "default": 2, "description": "2 = file element." },
                  "DocumentTypeId": { "type": "integer", "default": 1, "description": "1 = original (source) document." },
                  "file": { "type": "string", "format": "binary", "description": "The file to translate (use a real filename and content type, e.g. content.html / text/html)." }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The uploaded document object(s). Use the returned Id as the DocumentId in an order's Files array.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Document" }
                },
                "example": [ { "Id": 3538699, "Name": "content.html", "DocumentType": "Original" } ]
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/files/files/{orderId}": {
      "get": {
        "tags": ["Files"],
        "summary": "List files for an order",
        "operationId": "getFilesForOrder",
        "parameters": [ { "$ref": "#/components/parameters/OrderId" } ],
        "responses": {
          "200": {
            "description": "Files associated with the order.",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/FileObject" } }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/translation/quote": {
      "post": {
        "tags": ["Orders"],
        "summary": "Get a quote",
        "description": "Returns the word count, price, and available delivery options (with prices and delivery dates) for the given content, without placing an order. Upload the content first and reference it via Files (or send it inline via Groups). Select the product with OrderTypeConfigurationId + OrderTypeId.",
        "operationId": "getQuote",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/OrderRequest" },
              "example": {
                "OrderTypeConfigurationId": 167,
                "OrderTypeId": 55,
                "SourceLang": "de-CH",
                "TargetLanguages": ["fr-CH", "en-US"],
                "Files": [ { "Id": 380995, "Comment": "The main story" } ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The quote: word count, currency, and one Options entry per product with its delivery options.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/QuoteResponse" },
                "example": {
                  "Currency": "CHF",
                  "CurrencySymbol": "CHF",
                  "WordCount": 28,
                  "Options": [
                    {
                      "Name": "Übersetzung PREMIUM",
                      "OrderTypeConfigurationId": 167,
                      "OrderTypeId": 55,
                      "ShortDescription": "For demanding content where every word counts",
                      "DeliveryOptions": [
                        { "DeliveryId": 1, "Name": "Express", "Price": 90.0, "HourlyRate": null, "DeliveryDate": "2026-07-16T10:26:36Z", "IsDefaultDeliveryOption": false }
                      ]
                    }
                  ],
                  "AccountValid": true
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1.1/translation/order": {
      "post": {
        "tags": ["Orders"],
        "summary": "Create an order",
        "description": "Place a translation order. Returns one order object per target language. If CallbackUrl is set, Supertext POSTs the completed order object(s) to it when finished.",
        "operationId": "createOrder",
        "parameters": [
          {
            "name": "suppressConfirmationEmail",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean" },
            "description": "Suppress the order confirmation email."
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/OrderRequest" },
              "example": {
                "OrderTypeConfigurationId": 6,
                "DeliveryId": 1,
                "OrderName": "Homepage translation",
                "SourceLang": "de",
                "TargetLanguages": ["fr-CH", "en-US"],
                "ContentType": "text/html",
                "CallbackUrl": "https://yourdomain.com/supertext/callback",
                "ReferenceData": "ticket-4711",
                "Files": [ { "Id": 3538699, "Comment": "File to translate" } ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "One order object per target language.",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/OrderObject" } },
                "example": [
                  { "Id": 715113, "TargetLang": "fr-CH", "Status": "New", "ReferenceData": "ticket-4711" },
                  { "Id": 715114, "TargetLang": "en-US", "Status": "New", "ReferenceData": "ticket-4711" }
                ]
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        },
        "callbacks": {
          "orderCompleted": {
            "{$request.body#/CallbackUrl}": {
              "post": {
                "summary": "Order completed notification",
                "description": "Sent by Supertext when the order is completed. Body is the order object(s), including the Final file(s). Respond 2xx to acknowledge.",
                "requestBody": {
                  "required": true,
                  "content": {
                    "application/json": {
                      "schema": {
                        "oneOf": [
                          { "$ref": "#/components/schemas/OrderObject" },
                          { "type": "array", "items": { "$ref": "#/components/schemas/OrderObject" } }
                        ]
                      },
                      "example": {
                        "Id": 715113,
                        "Status": "Completed",
                        "ReferenceData": "ticket-4711",
                        "SourceLang": "de",
                        "TargetLang": "fr-CH",
                        "Files": [
                          { "Id": 8811, "Name": "content.html", "DocumentType": "Original", "ContentType": "text/html" },
                          { "Id": 8812, "Name": "content.html", "DocumentType": "Final", "ContentType": "text/html" }
                        ]
                      }
                    }
                  }
                },
                "responses": {
                  "200": { "description": "Acknowledged." }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/order/{orderId}": {
      "get": {
        "tags": ["Orders"],
        "summary": "Get an order",
        "description": "Fetch a single order with its current status and files.",
        "operationId": "getOrder",
        "parameters": [ { "$ref": "#/components/parameters/OrderId" } ],
        "responses": {
          "200": {
            "description": "The order.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OrderObject" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/order/feedback": {
      "post": {
        "tags": ["Orders"],
        "summary": "Provide feedback / reject an order",
        "operationId": "provideFeedback",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/FeedbackRequest" },
              "example": {
                "OrderId": 168110,
                "PostEditing": "true",
                "Rating": 4,
                "Comments": [ { "Comment": "Please keep the product name untranslated." } ]
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Feedback recorded." },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/order/status/{orderId}/{statusId}": {
      "put": {
        "tags": ["Orders"],
        "summary": "Change an order's status",
        "description": "Set an order's status. Commonly used to mark an order as Collected (statusId = 9).",
        "operationId": "changeOrderStatus",
        "parameters": [
          { "$ref": "#/components/parameters/OrderId" },
          {
            "name": "statusId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" },
            "description": "Target status id. 9 = Collected.",
            "example": 9
          }
        ],
        "responses": {
          "200": { "description": "Status updated." },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/api/v1/customer/orders/current/{pageSize}/{page}/{personId}": {
      "get": {
        "tags": ["Orders"],
        "summary": "List the current person's orders",
        "operationId": "listCurrentOrders",
        "parameters": [
          { "name": "pageSize", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 50 },
          { "name": "page", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 1 },
          { "name": "personId", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 598 },
          {
            "name": "queryFilter[IgnoreOrderStatusIds][]",
            "in": "query",
            "required": false,
            "schema": { "type": "integer" },
            "description": "Exclude orders with the given status id (repeatable).",
            "example": 22
          }
        ],
        "responses": {
          "200": {
            "description": "A page of orders.",
            "content": {
              "application/json": {
                "schema": { "type": "array", "items": { "$ref": "#/components/schemas/OrderObject" } }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/storage/file/{fileId}/{fileName}": {
      "get": {
        "tags": ["Files"],
        "summary": "Download a file",
        "description": "Download a document by id (e.g. the finished 'Final' file). Older integrations may use /filedownloads/file/{fileId}/{fileName}.",
        "operationId": "downloadFile",
        "parameters": [
          { "name": "fileId", "in": "path", "required": true, "schema": { "type": "integer" }, "example": 1964676 },
          { "name": "fileName", "in": "path", "required": true, "schema": { "type": "string" }, "example": "translation.html" }
        ],
        "responses": {
          "200": {
            "description": "The file contents.",
            "content": {
              "application/octet-stream": { "schema": { "type": "string", "format": "binary" } },
              "text/html": { "schema": { "type": "string" } }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "basicAuth": {
        "type": "http",
        "scheme": "basic",
        "description": "HTTP Basic: username = account email, password = Legacy API Key."
      }
    },
    "parameters": {
      "OrderId": {
        "name": "orderId",
        "in": "path",
        "required": true,
        "schema": { "type": "integer" },
        "description": "Supertext order id.",
        "example": 715113
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid credentials.",
        "content": {
          "application/json": {
            "schema": { "type": "object", "properties": { "Message": { "type": "string" } } }
          }
        }
      }
    },
    "schemas": {
      "OrderRequest": {
        "type": "object",
        "required": ["OrderTypeConfigurationId", "SourceLang", "TargetLanguages"],
        "description": "Order (and quote) request. Provide content via exactly one of `Files` or `Groups`. An order additionally requires `DeliveryId` and `OrderName`; a quote additionally uses `OrderTypeId`.",
        "properties": {
          "OrderTypeConfigurationId": { "type": "integer", "description": "Product / quality tier (account-specific).", "example": 6 },
          "OrderTypeId": { "type": "integer", "description": "Matching product type id, used together with OrderTypeConfigurationId when requesting a quote (account-specific).", "example": 55 },
          "DeliveryId": { "type": "integer", "description": "Delivery speed. 1=Express, 2=24h, 3=48h, 4=3 days, 5=1 week. Required for an order; omit for a quote (a quote returns the available delivery options).", "example": 1 },
          "SourceLang": { "type": "string", "description": "Source language (2-letter or regional).", "example": "de" },
          "TargetLanguages": { "type": "array", "items": { "type": "string" }, "description": "Target languages; one order is created per language.", "example": ["fr-CH", "en-US"] },
          "OrderName": { "type": "string", "example": "Homepage translation" },
          "ContentType": { "type": "string", "example": "text/html" },
          "CallbackUrl": { "type": "string", "format": "uri", "description": "URL Supertext POSTs to on completion.", "example": "https://yourdomain.com/supertext/callback" },
          "ReferenceData": { "type": "string", "description": "Opaque correlation string, echoed back in the callback.", "example": "ticket-4711" },
          "AdditionalInformation": { "type": "string", "description": "Free-text instructions for the translator." },
          "Currency": { "type": "string", "example": "chf" },
          "Deadline": { "type": "string", "description": "ISO-8601 desired deadline.", "example": "2026-02-09T13:46:47.0000000" },
          "ServiceTypeId": { "type": "integer", "description": "Legacy service type (quote); account-specific.", "example": 46 },
          "Referrer": { "type": "string", "example": "X-System Integration" },
          "SystemName": { "type": "string", "example": "WordPress" },
          "SystemVersion": { "type": "string", "example": "6.7" },
          "ComponentName": { "type": "string", "example": "supertext-polylang" },
          "ComponentVersion": { "type": "string", "example": "1.0" },
          "Links": { "type": "array", "items": { "$ref": "#/components/schemas/Link" } },
          "Files": { "type": "array", "items": { "$ref": "#/components/schemas/FileRef" }, "description": "Reference previously uploaded documents." },
          "Groups": { "type": "array", "items": { "$ref": "#/components/schemas/Group" }, "description": "Inline content." }
        }
      },
      "FileRef": {
        "type": "object",
        "required": ["Id"],
        "properties": {
          "Id": { "type": "integer", "description": "DocumentId returned by the upload endpoint.", "example": 3538699 },
          "Comment": { "type": "string", "nullable": true }
        }
      },
      "Group": {
        "type": "object",
        "properties": {
          "GroupId": { "type": "string", "example": "Group1" },
          "Context": { "type": "string", "nullable": true, "example": "Some Node" },
          "Items": { "type": "array", "items": { "$ref": "#/components/schemas/GroupItem" } }
        }
      },
      "GroupItem": {
        "type": "object",
        "required": ["Id", "Content"],
        "properties": {
          "Id": { "type": "string", "description": "Your identifier for the string (returned unchanged).", "example": "1" },
          "Content": { "type": "string", "description": "Text/HTML to translate.", "example": "<div>Hello</div>" },
          "Comment": { "type": "string", "nullable": true },
          "Context": { "type": "string", "nullable": true }
        }
      },
      "Link": {
        "type": "object",
        "properties": {
          "Url": { "type": "string", "format": "uri", "example": "http://en.wikipedia.org/wiki/Amalfi_Cathedral" },
          "Comment": { "type": "string", "example": "Background to the text" }
        }
      },
      "OrderObject": {
        "type": "object",
        "description": "An order. One is created per target language.",
        "properties": {
          "Id": { "type": "integer", "description": "OrderId.", "example": 715113 },
          "Status": { "type": "string", "description": "Textual status, e.g. New, In progress, Quality check, Completed.", "example": "Completed" },
          "SourceLang": { "type": "string", "example": "de" },
          "TargetLang": { "type": "string", "example": "fr-CH" },
          "OrderName": { "type": "string", "example": "Homepage translation" },
          "ReferenceData": { "type": "string", "example": "ticket-4711" },
          "Files": { "type": "array", "items": { "$ref": "#/components/schemas/FileObject" } }
        }
      },
      "FileObject": {
        "type": "object",
        "properties": {
          "Id": { "type": "integer", "example": 8812 },
          "Name": { "type": "string", "example": "content.html" },
          "DocumentType": { "type": "string", "enum": ["Original", "Final"], "description": "Final = the finished translation to download.", "example": "Final" },
          "ContentType": { "type": "string", "example": "text/html" }
        }
      },
      "Document": {
        "type": "object",
        "properties": {
          "Id": { "type": "integer", "description": "DocumentId.", "example": 3538699 },
          "Name": { "type": "string", "example": "content.html" },
          "DocumentType": { "type": "string", "enum": ["Original", "Final"], "example": "Original" }
        }
      },
      "FeedbackRequest": {
        "type": "object",
        "required": ["OrderId"],
        "properties": {
          "OrderId": { "type": "integer", "example": 168110 },
          "PostEditing": { "type": "string", "example": "true" },
          "Rating": { "type": "integer", "minimum": 1, "maximum": 5, "example": 4 },
          "Comments": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": { "Comment": { "type": "string" } }
            }
          }
        }
      },
      "QuoteResponse": {
        "type": "object",
        "description": "Result of a quote request.",
        "properties": {
          "Currency": { "type": "string", "description": "Currency of the quoted prices (the account currency).", "example": "CHF" },
          "CurrencySymbol": { "type": "string", "example": "CHF" },
          "WordCount": { "type": "integer", "description": "Authoritative source word count for the submitted content.", "example": 28 },
          "AccountValid": { "type": "boolean", "description": "false when the request was unauthenticated / the account can't order.", "example": true },
          "Options": {
            "type": "array",
            "description": "One entry per requested product (OrderTypeConfigurationId).",
            "items": { "$ref": "#/components/schemas/QuoteOption" }
          }
        }
      },
      "QuoteOption": {
        "type": "object",
        "properties": {
          "Name": { "type": "string", "example": "Übersetzung PREMIUM" },
          "OrderTypeConfigurationId": { "type": "integer", "example": 167 },
          "OrderTypeId": { "type": "integer", "example": 55 },
          "ShortDescription": { "type": "string", "example": "For demanding content where every word counts" },
          "Description": { "type": "string" },
          "DeliveryOptions": {
            "type": "array",
            "description": "Available delivery speeds for this product + language pair. Not every language pair offers the same set — build delivery choices from this list.",
            "items": { "$ref": "#/components/schemas/DeliveryOption" }
          }
        }
      },
      "DeliveryOption": {
        "type": "object",
        "properties": {
          "DeliveryId": { "type": "integer", "description": "1=Express, 2=24h, 3=48h, 4=3 days, 5=1 week.", "example": 1 },
          "Name": { "type": "string", "example": "Express" },
          "Price": { "type": "number", "format": "float", "example": 90.0 },
          "HourlyRate": { "type": "number", "format": "float", "nullable": true },
          "DeliveryDate": { "type": "string", "format": "date-time", "example": "2026-07-16T10:26:36Z" },
          "IsDefaultDeliveryOption": { "type": "boolean", "example": false }
        }
      }
    }
  }
}
